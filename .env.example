POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db

# Used by the backend to connect to Postgres inside Docker
DATABASE_URL=postgresql://app:app_password@db:5432/app_db

# For local development with Vite dev server
CORS_ORIGIN=http://localhost:5173

# Firebase (backend)
# Backend uses application default credentials. Point this to your service account JSON.
# Example (Docker/production): GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json
# Example (local): absolute path on your machine
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/firebase-service-account.json

# Firebase (frontend) - create a frontend/.env file using these keys with your values
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_APP_ID=your_app_id

